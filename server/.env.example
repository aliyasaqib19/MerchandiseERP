# ── Database ──────────────────────────────────────────────────────────────────
# Get this from neon.tech → your project → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Direct connection (no pooler) — required for Prisma migrations
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate two different random strings (64+ chars): https://generate-secret.vercel.app/64
JWT_ACCESS_SECRET="t8ZQsxPPiUcf134en7OERz1HyTxcAOsjZDThXPlU3B8="
JWT_REFRESH_SECRET="t8ZQsxPPiUcf134en7OERz1HyTxcAOsjZDThXPlU3B8="
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production: your Cloudflare Pages URL (e.g. https://aljibra.pages.dev)
# Multiple URLs: comma-separated
CLIENT_URL="http://localhost:5173"
